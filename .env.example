# Aegis402 environment — copy to `.env` and fill in. NEVER commit `.env`.
# All values below are read server-side only (oracle + skill). Do not expose
# the access token in any front-end.

# ─────────────────────────────────────────────────────────────────────────────
# Network (testnet for the buildathon)
CASPER_NETWORK=casper:casper-test
# Public testnet JSON-RPC (no auth) — raw chain queries / sanity checks
CASPER_RPC_URL=https://node.testnet.casper.network/rpc

# ─────────────────────────────────────────────────────────────────────────────
# CSPR.cloud — indexed on-chain data + the SAME token authorizes the facilitator.
# Get one at https://cspr.cloud (or ask in the buildathon Discord #ask-a-casper-dev).
# Sent as a raw UUID in the Authorization header (no "Bearer").
CSPR_CLOUD_TOKEN=
CSPR_CLOUD_REST_URL=https://node.testnet.cspr.cloud

# ─────────────────────────────────────────────────────────────────────────────
# x402 hosted facilitator (sponsored for the buildathon). Endpoints: /supported /verify /settle
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
# If the buildathon issues a separate facilitator key, set it; otherwise the
# oracle falls back to CSPR_CLOUD_TOKEN for the Authorization header.
X402_FACILITATOR_TOKEN=

# x402 payment asset — the CEP-18 test token the facilitator settles.
# 64-hex contract PACKAGE hash + its EIP-712 domain name/version/decimals.
# Get the testnet test-token hash + a faucet balance from the buildathon channel.
X402_ASSET_PACKAGE=
X402_ASSET_NAME=
X402_ASSET_VERSION=1
X402_ASSET_DECIMALS=9
# Price the oracle charges per /assess call, in base units (e.g. 7500000000 = 7.5 @ 9 decimals)
X402_PRICE=7500000000

# ─────────────────────────────────────────────────────────────────────────────
# SELLER (oracle): the account that RECEIVES payment — 66-char "00<64hex>" account hash
ORACLE_PAYEE_ADDRESS=
ORACLE_PORT=4021

# ─────────────────────────────────────────────────────────────────────────────
# BUYER (skill/agent): ED25519 keypair that signs the x402 authorization.
# Point at a PEM file path — NEVER paste the key inline or commit it.
# Fund the account from the testnet faucet: https://testnet.cspr.live/tools/faucet
AGENT_KEY_PATH=./keys/agent.pem
AGENT_KEY_ALGO=ed25519

# ─────────────────────────────────────────────────────────────────────────────
# Optional: CoinMarketCap for the market-context risk layer (degrades gracefully if unset)
CMC_API_KEY=

# Set to "1" to run the oracle against the in-repo MOCK facilitator (no token needed)
AEGIS_MOCK_FACILITATOR=0
